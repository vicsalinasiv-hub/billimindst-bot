# ─────────────────────────────────────────────────────────────
# @billimindst Bot — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy these into Railway → Your Project → Variables
# NEVER commit actual values to GitHub
# ─────────────────────────────────────────────────────────────

# Your X/Twitter handle (no @)
X_USERNAME=billimindst

# Your Substack connect.sid cookie value
# Get this from: Chrome → Substack.com → F12 → Application → Cookies → connect.sid
# ⚠️ This expires periodically — re-extract if bot stops posting
SUBSTACK_SID=your_connect_sid_value_here

# Your Substack handle (no @)
SUBSTACK_HANDLE=billionairemindset

# How often to check for new tweets (seconds). 600 = 10 minutes
POLL_INTERVAL_SEC=600
